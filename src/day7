import pandas as pd
file_path = "../data/jobs-usa.csv"
df = pd.read_csv(file_path)
print(df["salary"].value_counts().head(10))
print(df.describe())
df["salary"] = df["salary"].str.replace(r"\s+", "", regex=True)
# 1 清理字符串
df["salary"] = df["salary"].str.replace(r"\s+", "", regex=True)

# 2 拆分
df[["low", "high"]] = df["salary"].str.split("-", expand=True)

# 3 去符号
for col in ["low", "high"]:
    df[col] = (
        df[col].str.replace("$", "", regex=False).str.replace(",", "", regex=False)
    )

# 4 转数字
df["low"] = pd.to_numeric(df["low"], errors="coerce")
df["high"] = pd.to_numeric(df["high"], errors="coerce")

# 5 删除 NaN
df = df.dropna(subset=["low", "high"])

# 6 删除小时薪（假设 <1000 为小时）
df = df[df["low"] > 1000]

# 7 计算平均薪资
df["salary_clean"] = (df["low"] + df["high"]) / 2
print("\n=== 清洗后 salary 示例 ===")
print(df["salary"].head(10))

print("\n=== low / high 示例 ===")
print(df[["low", "high"]].head(10))

print("\n=== salary_clean 描述统计 ===")
print(df["salary_clean"].describe())
