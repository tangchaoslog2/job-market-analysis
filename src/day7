print(df["salary_clean"].describe())
print(df[df["salary_clean"] < 1000].head(10))

# 判断是否为月薪
df["is_monthly"] = df["low"] < 20000

# 转成年薪
df.loc[df["is_monthly"], "salary_clean"] = df.loc[df["is_monthly"], "salary_clean"] * 12
